generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum PlanType {
  FREE
  BASIC
  PRO
  UNLIMITED
}

enum StudioRole {
  OWNER
  ADMIN
  STAFF
  FINANCE
}

enum ActorType {
  USER
  CLIENT
  SYSTEM
}

enum LeadSource {
  MANUAL
  INQUIRY_FORM
  REFERRAL
  SOCIAL_MEDIA
  WEBSITE
  EMAIL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum ProjectStatus {
  INQUIRY
  BOOKED
  IN_PROGRESS
  EDITING
  DELIVERED
  ARCHIVED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  EXPIRED
  CANCELLED
  VOIDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
  CASH
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuestionnaireStatus {
  PENDING
  SENT
  IN_PROGRESS
  COMPLETED
}

enum GalleryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  EXPIRED
}

enum GalleryVisibility {
  PUBLIC
  PRIVATE
  PASSWORD
}

enum DownloadResolution {
  WEB
  HIGH
  ORIGINAL
}

enum ProofingStatus {
  NONE
  PENDING_CLIENT
  SUBMITTED_BY_CLIENT
  APPROVED
}

enum WatermarkPosition {
  CENTER
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
  TILED
}

enum AccessTokenType {
  LINK
  EMAIL
  PASSWORD
}

enum AssetType {
  IMAGE
  VIDEO
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DownloadType {
  SINGLE
  COLLECTION
  GALLERY
}

enum ZipStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum EmailTemplateType {
  GALLERY_SHARE
  GALLERY_REMINDER
  GALLERY_EXPIRY
  CONTRACT_SENT
  INVOICE_SENT
  PAYMENT_RECEIVED
  QUESTIONNAIRE_SENT
  PROPOSAL_SENT
  LEAD_CONFIRMATION
  CUSTOM
}

enum EmailLogStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum WorkflowTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  PROJECT_CREATED
  PROJECT_STATUS_CHANGED
  BOOKING_CREATED
  CONTRACT_SIGNED
  INVOICE_PAID
  GALLERY_PUBLISHED
  GALLERY_PROOFING_SUBMITTED
  QUESTIONNAIRE_COMPLETED
  DATE_RELATIVE
}

enum WorkflowStepType {
  SEND_EMAIL
  CREATE_TASK
  CHANGE_STATUS
  SEND_NOTIFICATION
  WAIT
}

enum WorkflowExecStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  LEAD_NEW
  LEAD_STATUS_CHANGED
  PROJECT_STATUS_CHANGED
  CONTRACT_SIGNED
  INVOICE_PAID
  PAYMENT_RECEIVED
  GALLERY_VIEWED
  GALLERY_PROOFING_SUBMITTED
  COMMENT_ADDED
  TASK_ASSIGNED
  TASK_DUE_SOON
  WORKFLOW_COMPLETED
  SYSTEM
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
  INACTIVE
}

// ============================================================
// PLATAFORMA
// ============================================================

model Studio {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  logoUrl           String?
  primaryColor      String?   @default("#111827")
  secondaryColor    String?
  website           String?
  email             String?
  phone             String?
  address           String?
  city              String?
  country           String?   @default("US")
  timezone          String    @default("UTC")
  currency          String    @default("USD")
  taxId             String?
  taxLabel          String?
  taxRate           Float     @default(0)
  invoicePrefix     String    @default("INV")
  invoiceFooter     String?
  contractFooter    String?
  storageUsedBytes  BigInt    @default(0)
  storageLimitBytes BigInt    @default(53687091200)
  plan              PlanType  @default(FREE)
  planExpiresAt     DateTime?
  stripeCustomerId  String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  studioUsers       StudioUser[]
  clients           Client[]
  leads             Lead[]
  projects          Project[]
  galleries         Gallery[]
  galleryFolders    GalleryFolder[]
  packages          Package[]
  contractTemplates ContractTemplate[]
  emailTemplates    EmailTemplate[]
  inquiryForms      InquiryForm[]
  questionnaires    Questionnaire[]
  workflows         Workflow[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  domains           StudioDomain[]
  tags              Tag[]
  invoices          Invoice[]
  emailLogs         EmailLog[]
  assets            Asset[]

  @@index([slug])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String
  avatar        String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  studioUsers       StudioUser[]
  accounts          Account[]
  sessions          Session[]
  assignedTasks     Task[]    @relation("TaskAssignee")
  assignedBookings  Booking[] @relation("BookingAssignee")
  auditLogs         AuditLog[]
  notifications     Notification[]
}

model StudioUser {
  id        String     @id @default(cuid())
  studioId  String
  userId    String
  role      StudioRole @default(STAFF)
  isActive  Boolean    @default(true)
  invitedAt DateTime?
  joinedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studioId, userId])
  @@index([studioId])
  @@index([userId])
}

// Auth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserToken {
  id        String     @id @default(cuid())
  userId    String?
  email     String
  token     String     @unique @default(cuid())
  type      String
  studioId  String?
  role      StudioRole?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([token])
  @@index([email])
}

model ClientUser {
  id            String    @id @default(cuid())
  studioId      String
  clientId      String?
  email         String
  name          String?
  emailVerified DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client              Client?              @relation(fields: [clientId], references: [id])
  galleryAccessTokens GalleryAccessToken[]
  favorites           Favorite[]
  comments            Comment[]
  downloads           Download[]

  @@unique([studioId, email])
  @@index([studioId])
  @@index([clientId])
}

// ============================================================
// CRM
// ============================================================

model Client {
  id        String    @id @default(cuid())
  studioId  String
  name      String
  email     String?
  phone     String?
  avatar          String?
  address         String?
  city            String?
  country         String?
  birthday        DateTime?
  notes           String?
  source          String?
  instagramHandle String?
  websiteUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  studio      Studio          @relation(fields: [studioId], references: [id], onDelete: Cascade)
  contacts    Contact[]
  projects    Project[]
  galleries   Gallery[]
  invoices    Invoice[]
  contracts   Contract[]
  clientUsers ClientUser[]
  tags        TagAssignment[]
  activities  ActivityLog[]
  notes_rel   Note[]          @relation("ClientNotes")

  @@index([studioId])
  @@index([studioId, email])
  @@index([deletedAt])
}

model Contact {
  id        String   @id @default(cuid())
  studioId  String
  clientId  String?
  leadId    String?
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([clientId])
  @@index([leadId])
}

model Lead {
  id                  String     @id @default(cuid())
  studioId            String
  name                String
  email               String?
  phone               String?
  source              LeadSource @default(MANUAL)
  status              LeadStatus @default(NEW)
  eventType           String?
  eventDate           DateTime?
  budget              Float?
  currency            String?    @default("USD")
  referral            String?
  notes               String?
  inquiryFormId       String?
  convertedAt         DateTime?
  convertedToClientId String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  studio         Studio             @relation(fields: [studioId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  tags           TagAssignment[]
  activities     ActivityLog[]
  notes_rel      Note[]             @relation("LeadNotes")
  formSubmission InquirySubmission?

  @@index([studioId])
  @@index([studioId, status])
  @@index([deletedAt])
}

model Project {
  id        String        @id @default(cuid())
  studioId      String
  clientId      String
  name          String
  type          String?
  status        ProjectStatus @default(INQUIRY)
  eventDate     DateTime?
  location      String?
  notes         String?
  color         String?
  packageId     String?
  totalAmount   Float?
  currency      String        @default("USD")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  studio                   Studio                    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  client                   Client                    @relation(fields: [clientId], references: [id])
  package                  Package?                  @relation(fields: [packageId], references: [id])
  bookings                 Booking[]
  galleries                Gallery[]
  contracts                Contract[]
  invoices                 Invoice[]
  proposals                Proposal[]
  tasks                    Task[]
  notes_rel                Note[]                    @relation("ProjectNotes")
  tags                     TagAssignment[]
  activities               ActivityLog[]
  questionnaireAssignments QuestionnaireAssignment[]
  workflowExecutions       WorkflowExecution[]

  @@index([studioId])
  @@index([studioId, status])
  @@index([clientId])
  @@index([deletedAt])
}

model Booking {
  id         String        @id @default(cuid())
  studioId   String
  projectId  String
  assignedTo String?
  title      String?
  type       String?
  status     BookingStatus @default(PENDING)
  startAt    DateTime
  endAt      DateTime?
  location   String?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedUser User?    @relation("BookingAssignee", fields: [assignedTo], references: [id])
  tasks        Task[]
  notes_rel    Note[]   @relation("BookingNotes")

  @@index([studioId])
  @@index([projectId])
  @@index([studioId, startAt])
}

model Task {
  id          String       @id @default(cuid())
  studioId    String
  projectId   String?
  bookingId   String?
  galleryId   String?
  assignedTo  String?
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  project  Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id])
  assignee User?    @relation("TaskAssignee", fields: [assignedTo], references: [id])

  @@index([studioId])
  @@index([assignedTo])
  @@index([projectId])
  @@index([studioId, status])
}

model Note {
  id        String   @id @default(cuid())
  studioId  String
  authorId  String
  content   String
  clientId  String?
  leadId    String?
  projectId String?
  bookingId String?
  galleryId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  client  Client?  @relation("ClientNotes", fields: [clientId], references: [id], onDelete: Cascade)
  lead    Lead?    @relation("LeadNotes", fields: [leadId], references: [id], onDelete: Cascade)
  project Project? @relation("ProjectNotes", fields: [projectId], references: [id], onDelete: Cascade)
  booking Booking? @relation("BookingNotes", fields: [bookingId], references: [id], onDelete: Cascade)
  gallery Gallery? @relation("GalleryNotes", fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([clientId])
  @@index([leadId])
  @@index([projectId])
}

model Tag {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  color     String?
  createdAt DateTime @default(now())

  studio      Studio          @relation(fields: [studioId], references: [id], onDelete: Cascade)
  assignments TagAssignment[]

  @@unique([studioId, name])
  @@index([studioId])
}

model TagAssignment {
  id        String   @id @default(cuid())
  tagId     String
  clientId  String?
  leadId    String?
  projectId String?
  galleryId String?
  createdAt DateTime @default(now())

  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gallery Gallery? @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([tagId])
  @@index([clientId])
  @@index([leadId])
  @@index([projectId])
}

model ActivityLog {
  id        String    @id @default(cuid())
  studioId   String
  actorId    String?
  actorType  ActorType @default(USER)
  entityType String?
  entityId   String?
  action     String
  metadata   Json?
  clientId   String?
  leadId     String?
  projectId  String?
  createdAt  DateTime  @default(now())

  client  Client?  @relation(fields: [clientId], references: [id])
  lead    Lead?    @relation(fields: [leadId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([studioId])
  @@index([clientId])
  @@index([leadId])
  @@index([projectId])
  @@index([createdAt])
}

// ============================================================
// DOCUMENTOS Y FINANZAS
// ============================================================

model ContractTemplate {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  body      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  studio    Studio     @relation(fields: [studioId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@index([studioId])
}

model Contract {
  id              String         @id @default(cuid())
  studioId        String
  projectId       String?
  clientId        String?
  templateId      String?
  title           String
  body            String
  status          ContractStatus @default(DRAFT)
  signingToken    String?        @unique
  sentAt          DateTime?
  viewedAt        DateTime?
  signedAt        DateTime?
  signerName      String?
  signerEmail     String?
  signerIp        String?
  signerUserAgent String?
  expiresAt       DateTime?
  pdfStorageKey   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  project  Project?          @relation(fields: [projectId], references: [id])
  client   Client?           @relation(fields: [clientId], references: [id])
  template ContractTemplate? @relation(fields: [templateId], references: [id])

  @@index([studioId])
  @@index([projectId])
  @@index([clientId])
  @@index([status])
}

model Package {
  id            String   @id @default(cuid())
  studioId      String
  name          String
  description   String?
  price         Float
  currency      String   @default("USD")
  durationHours Float?
  editedPhotos  Int?
  includes      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  studio        Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  projects      Project[]
  invoiceItems  InvoiceItem[]
  proposalItems ProposalItem[]

  @@index([studioId])
}

model Proposal {
  id         String         @id @default(cuid())
  studioId   String
  projectId  String?
  clientId   String?
  title      String
  notes      String?
  status     ProposalStatus @default(DRAFT)
  subtotal   Float          @default(0)
  taxRate    Float          @default(0)
  taxAmount  Float          @default(0)
  discount   Float          @default(0)
  total      Float          @default(0)
  currency   String         @default("USD")
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  project Project?       @relation(fields: [projectId], references: [id])
  items   ProposalItem[]

  @@index([studioId])
  @@index([projectId])
}

model ProposalItem {
  id          String   @id @default(cuid())
  proposalId  String
  packageId   String?
  name        String
  description String?
  quantity    Float    @default(1)
  unitPrice   Float
  total       Float
  order       Int      @default(0)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  package  Package? @relation(fields: [packageId], references: [id])

  @@index([proposalId])
}

model Invoice {
  id                   String        @id @default(cuid())
  studioId             String
  projectId            String?
  clientId             String?
  number               String
  title                String?
  notes                String?
  footer               String?
  status               InvoiceStatus @default(DRAFT)
  subtotal             Float         @default(0)
  taxRate              Float         @default(0)
  tax                  Float         @default(0)
  discount             Float         @default(0)
  total                Float         @default(0)
  amountPaid           Float         @default(0)
  amountDue            Float         @default(0)
  depositPercent       Float         @default(0)
  depositAmount        Float         @default(0)
  currency             String        @default("USD")
  dueDate              DateTime?
  sentAt               DateTime?
  viewedAt             DateTime?
  paidAt               DateTime?
  stripePaymentLinkId  String?
  stripePaymentLinkUrl String?
  pdfStorageKey        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  studio   Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  project  Project?      @relation(fields: [projectId], references: [id])
  client   Client?       @relation(fields: [clientId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@unique([studioId, number])
  @@index([studioId])
  @@index([projectId])
  @@index([clientId])
  @@index([studioId, status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  packageId   String?
  name        String?
  description String?
  quantity    Float    @default(1)
  unitPrice   Float
  taxRate     Float    @default(0)
  amount      Float
  sortOrder   Int      @default(0)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  package Package? @relation(fields: [packageId], references: [id])

  @@index([invoiceId])
}

model Payment {
  id                    String        @id @default(cuid())
  studioId              String
  invoiceId             String
  amount                Float
  currency              String        @default("USD")
  method                PaymentMethod @default(OTHER)
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  reference             String?
  notes                 String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([studioId])
}

// ============================================================
// FORMULARIOS Y CUESTIONARIOS
// ============================================================

model InquiryForm {
  id          String   @id @default(cuid())
  studioId    String
  name        String
  slug        String
  fields      Json
  isActive    Boolean  @default(true)
  notifyEmail String?
  redirectUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio      Studio               @relation(fields: [studioId], references: [id], onDelete: Cascade)
  submissions InquirySubmission[]

  @@unique([studioId, slug])
  @@index([studioId])
}

model InquirySubmission {
  id          String   @id @default(cuid())
  studioId    String
  formId      String
  leadId      String?  @unique
  data        Json
  submitterIp String?
  userAgent   String?
  createdAt   DateTime @default(now())

  form InquiryForm @relation(fields: [formId], references: [id])
  lead Lead?       @relation(fields: [leadId], references: [id])

  @@index([formId])
  @@index([studioId])
}

model Questionnaire {
  id          String   @id @default(cuid())
  studioId    String
  name        String
  description String?
  fields      Json
  isTemplate  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio      Studio                    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  assignments QuestionnaireAssignment[]

  @@index([studioId])
}

model QuestionnaireAssignment {
  id              String              @id @default(cuid())
  questionnaireId String
  projectId       String
  clientId        String?
  status          QuestionnaireStatus @default(PENDING)
  sentAt          DateTime?
  completedAt     DateTime?
  responses       Json?
  accessToken     String              @unique @default(cuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id])
  project       Project       @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([questionnaireId])
  @@index([accessToken])
}

// ============================================================
// GALERÍAS
// ============================================================

model GalleryFolder {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio    Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  galleries Gallery[]

  @@index([studioId])
}

model Gallery {
  id                 String            @id @default(cuid())
  studioId           String
  projectId          String?
  clientId           String?
  folderId           String?
  name               String
  slug               String
  description        String?
  coverAssetId       String?
  status             GalleryStatus     @default(DRAFT)
  visibility         GalleryVisibility @default(PRIVATE)
  passwordHash       String?
  requireEmail       Boolean           @default(false)
  allowDownload      Boolean           @default(true)
  downloadPin        String?
  downloadResolution DownloadResolution @default(ORIGINAL)
  downloadLimit      Int?
  allowProofing      Boolean           @default(false)
  proofingLimit      Int?
  proofingDeadline   DateTime?
  proofingStatus     ProofingStatus    @default(NONE)
  watermarkEnabled   Boolean           @default(false)
  watermarkText      String?
  watermarkStorageKey String?
  watermarkOpacity   Float             @default(0.5)
  watermarkPosition  WatermarkPosition @default(CENTER)
  brandingOverride   Json?
  shootDate          DateTime?
  expiresAt          DateTime?
  publishedAt        DateTime?
  assetCount         Int               @default(0)
  totalSizeBytes     BigInt            @default(0)
  viewCount          Int               @default(0)
  downloadCount      Int               @default(0)
  favoriteCount      Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  studio           Studio               @relation(fields: [studioId], references: [id], onDelete: Cascade)
  project          Project?             @relation(fields: [projectId], references: [id])
  client           Client?              @relation(fields: [clientId], references: [id])
  folder           GalleryFolder?       @relation(fields: [folderId], references: [id])
  assets           Asset[]
  collections      Collection[]
  accessTokens     GalleryAccessToken[]
  accessLogs       GalleryAccessLog[]
  downloads        Download[]
  tags             TagAssignment[]
  notes            Note[]               @relation("GalleryNotes")
  proofingSessions ProofingSession[]

  @@unique([studioId, slug])
  @@index([studioId])
  @@index([projectId])
  @@index([clientId])
  @@index([studioId, status])
  @@index([deletedAt])
}

model GalleryAccessToken {
  id           String          @id @default(cuid())
  galleryId    String
  clientUserId String?
  token        String          @unique @default(cuid())
  type         AccessTokenType @default(LINK)
  expiresAt    DateTime?
  usedAt       DateTime?
  createdAt    DateTime        @default(now())

  gallery    Gallery     @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  clientUser ClientUser? @relation(fields: [clientUserId], references: [id])

  @@index([galleryId])
  @@index([token])
}

model GalleryAccessLog {
  id           String   @id @default(cuid())
  galleryId    String
  clientUserId String?
  email        String?
  method       String
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([createdAt])
}

model Collection {
  id           String   @id @default(cuid())
  galleryId    String
  studioId     String
  name         String
  description  String?
  coverAssetId String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([studioId])
}

model Asset {
  id               String           @id @default(cuid())
  studioId         String
  galleryId        String
  filename         String
  originalName     String
  mimeType         String
  fileSize         Int
  width            Int?
  height           Int?
  status           ProcessingStatus @default(PENDING)
  sortOrder        Int              @default(0)
  originalKey      String?
  thumbKey         String?
  webKey           String?
  highKey          String?
  watermarkedKey   String?
  isFavorite       Boolean          @default(false)
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  gallery   Gallery    @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  studio    Studio     @relation(fields: [studioId], references: [id], onDelete: Cascade)
  favorites Favorite[]
  comments  Comment[]
  downloads Download[]

  @@index([galleryId])
  @@index([studioId])
  @@index([status])
  @@index([deletedAt])
}

model ProofingSession {
  id           String         @id @default(cuid())
  galleryId    String
  studioId     String
  maxFavorites Int?
  deadline     DateTime?
  status       ProofingStatus @default(PENDING_CLIENT)
  submittedAt  DateTime?
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
}

model Favorite {
  id           String    @id @default(cuid())
  assetId      String
  galleryId    String
  clientUserId String?
  visitorEmail String?
  createdAt    DateTime  @default(now())

  asset      Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  clientUser ClientUser? @relation(fields: [clientUserId], references: [id])

  @@unique([assetId, clientUserId])
  @@index([assetId])
  @@index([galleryId])
  @@index([clientUserId])
}

model Comment {
  id           String    @id @default(cuid())
  assetId      String
  galleryId    String
  clientUserId String?
  authorName   String?
  content      String
  isRead       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  asset      Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  clientUser ClientUser? @relation(fields: [clientUserId], references: [id])

  @@index([assetId])
  @@index([galleryId])
}

model Download {
  id            String             @id @default(cuid())
  galleryId     String
  assetId       String?
  collectionId  String?
  clientUserId  String?
  visitorEmail  String?
  resolution    DownloadResolution @default(ORIGINAL)
  type          DownloadType       @default(SINGLE)
  zipStorageKey String?
  zipStatus     ZipStatus?
  ip            String?
  createdAt     DateTime           @default(now())

  gallery    Gallery     @relation(fields: [galleryId], references: [id])
  asset      Asset?      @relation(fields: [assetId], references: [id])
  clientUser ClientUser? @relation(fields: [clientUserId], references: [id])

  @@index([galleryId])
  @@index([assetId])
  @@index([clientUserId])
}

// ============================================================
// EMAIL
// ============================================================

model EmailTemplate {
  id        String            @id @default(cuid())
  studioId  String
  name      String
  subject   String
  body      String
  type      EmailTemplateType @default(CUSTOM)
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

model EmailLog {
  id                  String         @id @default(cuid())
  studioId            String
  to                  String
  subject             String
  template            String?
  status              EmailLogStatus @default(QUEUED)
  providerMessageId   String?
  error               String?
  sentAt              DateTime?
  openedAt            DateTime?
  clickedAt           DateTime?
  bouncedAt           DateTime?
  projectId           String?
  galleryId           String?
  invoiceId           String?
  contractId          String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([to])
  @@index([projectId])
  @@index([status])
}

// ============================================================
// WORKFLOWS
// ============================================================

model Workflow {
  id            String          @id @default(cuid())
  studioId      String
  name          String
  description   String?
  trigger       WorkflowTrigger
  triggerConfig Json?
  isActive      Boolean         @default(true)
  runCount      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  studio     Studio              @relation(fields: [studioId], references: [id], onDelete: Cascade)
  steps      WorkflowStep[]
  executions WorkflowExecution[]

  @@index([studioId])
  @@index([studioId, isActive])
}

model WorkflowStep {
  id         String           @id @default(cuid())
  workflowId String
  type       WorkflowStepType
  config     Json
  order      Int
  delayHours Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowExecution {
  id          String             @id @default(cuid())
  workflowId  String
  studioId    String
  projectId   String?
  status      WorkflowExecStatus @default(RUNNING)
  currentStep Int                @default(0)
  log         Json?
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  error       String?

  workflow Workflow @relation(fields: [workflowId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])

  @@index([workflowId])
  @@index([projectId])
  @@index([studioId])
}

// ============================================================
// SISTEMA
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  studioId  String
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  projectId String?
  galleryId String?
  clientId  String?
  createdAt DateTime         @default(now())

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([studioId, userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id           String    @id @default(cuid())
  studioId     String
  actorId      String?
  actorEmail   String?
  actorType    ActorType @default(USER)
  action       String
  entityType   String?
  entityId     String?
  previousData Json?
  newData      Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  actor  User?   @relation(fields: [actorId], references: [id])
  studio Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model StudioDomain {
  id          String       @id @default(cuid())
  studioId    String
  domain      String       @unique
  type        DomainType   @default(SUBDOMAIN)
  status      DomainStatus @default(PENDING)
  verifiedAt  DateTime?
  sslIssuedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([domain])
}
