# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Federación cross-subdomain ───────────────────────────────────────────────
# Dominio del cookie de Supabase Auth para que la sesión sea válida en hub.* +
# my.* + fi.* + inventario.* simultáneamente (SSO sin re-login).
# Producción: ".abbypixel.com". Dev (localhost): dejar vacío.
AUTH_COOKIE_DOMAIN=
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=

# JWT compartido con el hub para el endpoint /api/auth/hub-sso.
# El hub firma el JWT al hacer click "Abrir CRM Studio"; este módulo lo valida
# y crea sesión local. Misma key debe estar en HUB_JWT_SECRET del hub.
HUB_JWT_SECRET=
HUB_JWT_ISSUER=studio-hub

# URL del hub para emitir eventos federados (client.created, invoice.paid, etc.)
# El hub deduplica por external_reference, así que retries son seguros.
HUB_URL=https://hub.abbypixel.com
HUB_HMAC_SECRET=

# ─── Supabase (backend principal post-2026-04-18) ─────────────────────────────
# URL del proyecto: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://kbrcqyjnrbjlzfolpcsx.supabase.co"
# anon / publishable key — seguro para exponer al cliente (RLS la protege)
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxx_change_me"
# service role — SOLO backend. NUNCA en código de cliente.
SUPABASE_SERVICE_ROLE_KEY="service_role_change_me"

# ─── Database (legacy — Prisma, deprecarse al completar migración) ────────────
DATABASE_URL="postgresql://studioflow:CAMBIA_ESTA_CONTRASENA@localhost:5432/studioflow?schema=public"

# ─── Auth (transición) ────────────────────────────────────────────────────────
# Mientras NextAuth esté en uso para el panel, se mantiene. Supabase Auth lo
# reemplazará en Fase 0.6.
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"
NEXTAUTH_URL=http://localhost:3000

# ─── Redis (BullMQ — opcional, ya no requerido con pg_cron + Edge Functions) ──
REDIS_URL="redis://localhost:6379"

# ─── Integraciones externas ───────────────────────────────────────────────────
# NOTA: en la nueva arquitectura, Resend / Google Calendar / dominio / pasarelas
# se configuran IN-APP (/settings/integrations) y se guardan en la tabla
# `studio_integrations` encriptadas, no aquí. Estas variables ya no son
# requeridas para correr la app; se mantienen solo como fallback legado.

# ─── Email (legacy) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=""
# EMAIL_FROM=""
# EMAIL_FROM_NAME=""

# ─── Payments (legacy) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Storage (legacy — reemplazado por Supabase Storage) ──────────────────────
# STORAGE_ENDPOINT=""
# STORAGE_REGION="auto"
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""
# STORAGE_BUCKET=""
# STORAGE_PUBLIC_URL=""
