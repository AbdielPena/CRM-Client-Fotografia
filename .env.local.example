# .env para desarrollo local con Docker Compose
# Copia este archivo como .env y ajusta NEXTAUTH_SECRET

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Base de datos (docker compose up -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/studioflow?schema=public"

# Auth
NEXTAUTH_SECRET="cambia-esto-por-un-string-random-de-32-chars"
NEXTAUTH_URL=http://localhost:3000

# Redis (docker compose up -d)
REDIS_URL="redis://localhost:6379"

# MinIO local (docker compose up -d → configura bucket en localhost:9001)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID="minioadmin"
STORAGE_SECRET_ACCESS_KEY="minioadmin"
STORAGE_BUCKET="studioflow"
STORAGE_PUBLIC_URL="http://localhost:9000/studioflow"

# Email (opcional en dev — sin esto los emails no se envían)
RESEND_API_KEY=""
EMAIL_FROM="noreply@localhost"
EMAIL_FROM_NAME="StudioFlow Dev"

# Stripe (opcional en dev)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
